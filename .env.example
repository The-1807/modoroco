MODOROCO_ENVIRONMENT=development
MODOROCO_DATABASE_URL=postgresql+asyncpg://modoroco:change-me@postgres:5432/modoroco
# Generate a high-entropy value for local bootstrap; never reuse it in production.
MODOROCO_BOOTSTRAP_API_KEY=
MODOROCO_WORKER_POLL_SECONDS=1.0
MODOROCO_WORKER_BATCH_SIZE=50
POSTGRES_PASSWORD=change-me

