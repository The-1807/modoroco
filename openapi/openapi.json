{
  "components": {
    "schemas": {
      "Command": {
        "enum": [
          "start",
          "pause",
          "resume",
          "skip_phase",
          "extend_phase",
          "complete_phase",
          "cancel",
          "restart"
        ],
        "title": "Command",
        "type": "string"
      },
      "CommandInput": {
        "properties": {
          "command": {
            "$ref": "#/components/schemas/Command"
          },
          "expected_version": {
            "minimum": 1.0,
            "title": "Expected Version",
            "type": "integer"
          },
          "extend_seconds": {
            "anyOf": [
              {
                "maximum": 14400.0,
                "minimum": 1.0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Extend Seconds"
          }
        },
        "required": [
          "command",
          "expected_version"
        ],
        "title": "CommandInput",
        "type": "object"
      },
      "FamilyCreate": {
        "properties": {
          "description": {
            "default": "",
            "maxLength": 2000,
            "title": "Description",
            "type": "string"
          },
          "name": {
            "maxLength": 120,
            "minLength": 1,
            "title": "Name",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "title": "FamilyCreate",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "PhaseInput": {
        "properties": {
          "duration_seconds": {
            "maximum": 14400.0,
            "minimum": 1.0,
            "title": "Duration Seconds",
            "type": "integer"
          },
          "extendable": {
            "default": true,
            "title": "Extendable",
            "type": "boolean"
          },
          "key": {
            "maxLength": 60,
            "minLength": 1,
            "pattern": "^[a-z0-9_-]+$",
            "title": "Key",
            "type": "string"
          },
          "max_duration_seconds": {
            "default": 14400,
            "maximum": 86400.0,
            "minimum": 1.0,
            "title": "Max Duration Seconds",
            "type": "integer"
          },
          "name": {
            "maxLength": 100,
            "minLength": 1,
            "title": "Name",
            "type": "string"
          },
          "phase_type": {
            "$ref": "#/components/schemas/PhaseType"
          },
          "skippable": {
            "default": true,
            "title": "Skippable",
            "type": "boolean"
          }
        },
        "required": [
          "key",
          "name",
          "phase_type",
          "duration_seconds"
        ],
        "title": "PhaseInput",
        "type": "object"
      },
      "PhaseType": {
        "enum": [
          "focus",
          "short_break",
          "long_break",
          "custom"
        ],
        "title": "PhaseType",
        "type": "string"
      },
      "SessionCreate": {
        "properties": {
          "family_version_id": {
            "format": "uuid",
            "title": "Family Version Id",
            "type": "string"
          }
        },
        "required": [
          "family_version_id"
        ],
        "title": "SessionCreate",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "VersionCreate": {
        "properties": {
          "phases": {
            "items": {
              "$ref": "#/components/schemas/PhaseInput"
            },
            "maxItems": 32,
            "minItems": 1,
            "title": "Phases",
            "type": "array"
          }
        },
        "required": [
          "phases"
        ],
        "title": "VersionCreate",
        "type": "object"
      }
    }
  },
